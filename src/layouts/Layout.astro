---
import "../styles/global.css";

interface Props {
	title?: string;
}

const { title = "Kalon Solutions" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body
		class="min-h-screen bg-gray-50 font-sans text-gray-900 antialiased selection:bg-blue-200"
	>
		<!-- Godray effect - textured central beam -->
		<div class="pointer-events-none absolute inset-0" aria-hidden="true">
			<!-- Base beam shape -->
			<div
				class="absolute inset-0 opacity-40"
				style="
					background: linear-gradient(
						45deg,
						transparent 30%,
						oklch(0.98 0.02 60) 45%,
						oklch(0.99 0.015 65) 50%,
						oklch(0.98 0.02 60) 55%,
						transparent 70%
					);
				"
			>
			</div>
			<!-- Internal ray texture -->
			<div
				class="absolute inset-0 opacity-35"
				style="
					background-image: repeating-linear-gradient(
						45deg,
						transparent 0%,
						transparent 2%,
						oklch(0.98 0.025 65) 2.5%,
						oklch(0.99 0.02 60) 3%,
						oklch(0.98 0.025 65) 3.5%,
						transparent 4%,
						transparent 8%
					);
					mask-image: linear-gradient(
						45deg,
						transparent 32%,
						black 44%,
						black 56%,
						transparent 68%
					);
				"
			>
			</div>
			<!-- Soft outer glow -->
			<div
				class="absolute inset-0 opacity-30 blur-3xl"
				style="
					background: linear-gradient(
						45deg,
						transparent 25%,
						oklch(0.97 0.03 58) 40%,
						oklch(0.98 0.025 62) 50%,
						oklch(0.97 0.03 58) 60%,
						transparent 75%
					);
				"
			>
			</div>
		</div>
		<!-- Paper texture overlay -->
		<div
			class="pointer-events-none fixed inset-0 opacity-[0.025]"
			style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"
			aria-hidden="true"
		>
		</div>
		<div class="relative">
			<slot />
		</div>
	</body>
</html>
